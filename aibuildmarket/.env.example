# Database — Neon or Vercel Postgres connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js
AUTH_SECRET="generate-with: openssl rand -base64 32"

# Stripe — real keys from your Stripe dashboard. Connect must be enabled
# on the account for the destination-charge flow in /api/checkout to work.
STRIPE_SECRET_KEY="sk_live_or_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Public site URL, used for Stripe redirect URLs, verification emails, sitemap
NEXT_PUBLIC_URL="https://aibuildmarket.com"

# Outbound email (signup verification) — any SMTP relay works. Free options:
# a Gmail account with an App Password, or Resend's free-tier SMTP relay.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@gmail.com"
SMTP_PASS="app-password-here"
EMAIL_FROM="AI Build Market <you@gmail.com>"
